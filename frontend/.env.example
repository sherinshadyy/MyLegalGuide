PORT=3000
JWT_SECRET=change_this_secret_in_prod

# MySQL (same database as backend Python API)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mylegalguide

# Python RAG API — run start-rag.ps1 in backend first
RAG_API_URL=http://127.0.0.1:8000
RAG_API_TIMEOUT_MS=120000

# Optional: set here if you prefer (also set in backend/.env for rag_api.py)
# GROQ_API_KEY=your_groq_api_key_here
