# Copy to .env and fill in your Groq API key (https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=mylegalguide

RAG_STORE=rag_store
RAG_API_HOST=127.0.0.1
RAG_API_PORT=8000
RAG_TOP_K=5
RAG_USE_RERANK=0
RAG_QUERY_REWRITE=1

# Voice STT (Egyptian Arabic) — pip install -r requirements-voice.txt + ffmpeg on PATH
VOICE_STT_ENABLED=1
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
